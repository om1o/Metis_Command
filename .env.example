# Metis Command — environment template. Copy to .env and fill real values.

# ── Supabase (cloud auth + storage + plugin store) ───────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# IMPORTANT: for client-side sign-in (email/password + Google/GitHub OAuth),
# this must be your Supabase **anon** key (NOT the service role key).
SUPABASE_KEY=your-anon-key

# ── Ollama (local AI runtime) ────────────────────────────────────────────────
OLLAMA_BASE=http://localhost:11434

# ── OpenAI (cloud fallback for CrewAI when no Ollama) ────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o

# ── Groq (FREE genius brain — https://console.groq.com) ─────────────────────
# Sign up in 30 seconds, no credit card required.
# Provides llama-3.3-70b-versatile as a free, ultra-fast Genius fallback.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE=https://api.groq.com/openai/v1

# ── GLM / Z.ai (apex "genius" brain — GLM-4.6) ───────────────────────────────
GLM_API_KEY=
GLM_MODEL=glm-4.6
GLM_BASE=https://open.bigmodel.cn/api/paas/v4

# ── Orchestrator Wallet (simulated budget, optional Stripe Issuing) ──────────
METIS_WALLET_CAP_CENTS=10000
METIS_WALLET_MODE=simulated
STRIPE_ISSUING_KEY=

# ── Daily briefing (optional email + time override) ──────────────────────────
DAILY_PLAN_EMAIL=
DAILY_BRIEFING_TIME=07:00

# ── Stripe (marketplace + subscription tiers) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_pro_xxx
STRIPE_PRICE_ENTERPRISE=price_enterprise_xxx

# ── Email (SMTP outreach via comms_link.py) ──────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── Twilio (SMS outreach) ────────────────────────────────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ── Metis runtime ────────────────────────────────────────────────────────────
METIS_API_PORT=7331
METIS_UI_PORT=8501
METIS_TIER_OVERRIDE=
METIS_THEME=obsidian
# Public links (optional; About panel + marketing consistency)
# METIS_SUPPORT_URL=https://github.com/yourorg/yourrepo/discussions
# METIS_RELEASES_URL=https://github.com/yourorg/yourrepo/releases
# METIS_MARKETING_SITE=https://your-landing-site.example
